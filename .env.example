# ============================================
# LOCAL DEVELOPMENT (defaults — no changes needed)
# ============================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017/deepfake

# Backend
PORT=5000
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:3000

# Inference
INFERENCE_URL=http://localhost:8000
MODEL_PATH=./efficientnet_deepfake_ultra_final.h5
CLASSIFICATION_THRESHOLD=0.50

# Inference → Backend (for progress reporting)
BACKEND_URL=http://localhost:5000

# Frontend (set at build time via REACT_APP_ prefix)
REACT_APP_API_URL=http://localhost:5000/api

# ============================================
# PRODUCTION EXAMPLE VALUES
# ============================================
# Replace with your actual deployed URLs:
#
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/deepfake
# FRONTEND_URL=https://your-app.vercel.app
# INFERENCE_URL=https://your-space.hf.space
# BACKEND_URL=https://your-backend.onrender.com
# REACT_APP_API_URL=https://your-backend.onrender.com/api

